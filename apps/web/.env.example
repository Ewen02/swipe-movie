# =============================================================================
# API Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3001

# =============================================================================
# Database Configuration (shared with API)
# =============================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swipe

# =============================================================================
# Better Auth Configuration
# =============================================================================
# The URL where your Next.js app is running
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_AUTH_URL=http://localhost:3000

# ⚠️  CRITICAL SECURITY: Generate a secure random secret for production
# Run this command to generate a secure secret:
#   openssl rand -base64 32
#
# NEVER use the default value in production! This compromises session security.
# Each environment (dev, staging, prod) should have a unique secret.
BETTER_AUTH_SECRET=your-better-auth-secret-change-this-in-production

# =============================================================================
# Google OAuth Credentials
# =============================================================================
# Setup instructions:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new "OAuth 2.0 Client ID" (or use existing)
# 3. Set application type to "Web application"
# 4. Add authorized redirect URIs:
#    - Development: http://localhost:3000/api/auth/callback/google
#    - Production: https://yourdomain.com/api/auth/callback/google
# 5. Copy the Client ID and Client Secret below
#
# Documentation: https://www.better-auth.com/docs/authentication/social
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# Internal API Secret (shared between Web and API for secure server-to-server communication)
# Generate with: openssl rand -base64 32
# MUST match the INTERNAL_API_SECRET in the API .env
# =============================================================================
INTERNAL_API_SECRET=your-internal-api-secret-change-this-in-production

# =============================================================================
# Google Analytics (Optional)
# =============================================================================
# Leave empty to disable Google Analytics
#
# Setup instructions:
# 1. Go to https://analytics.google.com
# 2. Create a GA4 property
# 3. Get your Measurement ID (format: G-XXXXXXXXXX)
#
NEXT_PUBLIC_GA_ID=

# =============================================================================
# PostHog Product Analytics (Optional)
# =============================================================================
# Leave empty to disable PostHog
#
# Setup instructions:
# 1. Create account at https://posthog.com
# 2. Get your Project API Key from Settings > Project
# 3. Paste below
#
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# =============================================================================
# Sentry Error Monitoring (Optional)
# =============================================================================
# Leave empty to disable error monitoring
#
# Setup instructions:
# 1. Create account at https://sentry.io
# 2. Create a new project
# 3. Get your DSN from: https://sentry.io/settings/projects/
# 4. Paste the DSN below
#
# Format: https://<key>@<organization>.ingest.sentry.io/<project>
NEXT_PUBLIC_SENTRY_DSN=
